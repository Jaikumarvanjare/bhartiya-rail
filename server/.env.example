# ── Server ─────────────────────────────────────────────────────────────
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# ── Database (match docker-compose ports) ──────────────────────────────
DATABASE_URL="postgresql://bharat:bharat@localhost:5433/bharat_rail?schema=public"

# ── Redis (seat locks, tatkal queue) ───────────────────────────────────
REDIS_URL="redis://localhost:6380"
SEAT_LOCK_TTL_SECONDS=900

# ── Auth (JWT) ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-use-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-use-long-random-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
OTP_TTL_SECONDS=300

# ── Booking rules ──────────────────────────────────────────────────────
TATKAL_DAILY_LIMIT=3

# ── Live schedule & train intelligence (optional) ─────────────────────
# Required for real between-station search, live status, station boards,
# train schedule, and route geometry. Get a key from your schedule provider.
# Free tiers often cap daily requests (e.g. 50/day).
RAILRADAR_API_KEY=""
RAILRADAR_BASE_URL="https://api.railradar.in"
